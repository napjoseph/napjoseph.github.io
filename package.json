{
  "name": "napjoseph.github.io",
  "description": "Personal site of Nap Joseph Calub.",
  "version": "0.0.1",
  "keywords": [
    "blog"
  ],
  "author": {
    "name": "Nap Joseph Calub",
    "email": "hello@napjose.ph",
    "url": "https://napjose.ph"
  },
  "scripts": {
    "clean": "rimraf dist",
    "watch:webpack": "webpack --config=node_modules/laravel-mix/setup/webpack.config.js --watch",
    "watch:eleventy": "eleventy --config=eleventy.config.js --watch --quiet",
    "watch:prettier": "onchange '**/*.{js,json,html,md,ts,css,scss,yaml,yml}' --exclude-path .prettierignore -- prettier --write {{changed}}",
    "watch:browser-sync": "browser-sync start --server 'dist' --files 'dist' --no-open --no-online",
    "watch": "cross-env NODE_ENV=development ELEVENTY_ENV=development npm-run-all clean --parallel watch:*",
    "build:webpack": "webpack --config=node_modules/laravel-mix/setup/webpack.config.js",
    "build:eleventy": "eleventy --config=eleventy.config.js",
    "build": "cross-env NODE_ENV=production ELEVENTY_ENV=production npm-run-all clean build:*",
    "serve": "npm-run-all clean build watch:browser-sync",
    "start": "run-s watch"
  },
  "dependencies": {
    "@11ty/eleventy": "0.10.0",
    "@fullhuman/postcss-purgecss": "2.1.0",
    "autoprefixer": "9.7.4",
    "cross-env": "7.0.0",
    "css-loader": "3.4.2",
    "html-minifier": "4.0.0",
    "laravel-mix": "5.0.1",
    "npm-run-all": "4.1.5",
    "resolve-url-loader": "3.1.0",
    "rimraf": "3.0.2",
    "sass": "1.26.2",
    "sass-loader": "8.0.2",
    "style-loader": "1.1.3",
    "tailwindcss": "1.2.0",
    "ts-loader": "6.2.1",
    "typescript": "3.8.3"
  },
  "devDependencies": {
    "browser-sync": "2.26.7",
    "husky": "4.2.3",
    "lint-staged": "10.0.8",
    "onchange": "6.1.0",
    "prettier": "1.19.1",
    "stylelint": "13.2.0",
    "stylelint-config-prettier": "8.0.1",
    "stylelint-config-standard": "20.0.0",
    "stylelint-no-unsupported-browser-features": "4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/napjoseph/napjoseph.github.io.git"
  },
  "homepage": "https://github.com/napjoseph/napjoseph.github.io#readme",
  "bugs": {
    "url": "https://github.com/napjoseph/napjoseph.github.io/issues"
  },
  "license": "MIT",
  "private": true
}
