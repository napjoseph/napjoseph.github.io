{
  "name": "napjoseph.github.io",
  "description": "Personal site of Nap Joseph Calub.",
  "version": "0.0.1",
  "keywords": [
    "blog"
  ],
  "author": {
    "name": "Nap Joseph Calub",
    "email": "hello@napjose.ph",
    "url": "https://napjose.ph"
  },
  "scripts": {
    "clean": "rimraf dist",
    "watch:prettier": "onchange '**/*.{js,json,html,md,ts,css,scss,yaml,yml}' --exclude-path .prettierignore -- prettier --write {{changed}}",
    "watch:eleventy": "ELEVENTY_ENV=development eleventy --watch --quiet --config=eleventy.config.js",
    "watch:webpack": "webpack --mode=development --watch --config webpack.dev.config.js",
    "watch:browser-sync": "browser-sync start --server 'dist' --files 'dist' --no-open --no-online",
    "watch": "npm-run-all clean --parallel watch:*",
    "build:eleventy": "ELEVENTY_ENV=production eleventy --config=eleventy.config.js",
    "build:webpack": "webpack -p --config webpack.prod.config.js",
    "build": "npm-run-all clean --parallel build:*",
    "serve": "npm-run-all clean build watch:browser-sync"
  },
  "dependencies": {
    "@11ty/eleventy": "0.10.0",
    "npm-run-all": "4.1.5",
    "rimraf": "3.0.2",
    "webpack": "4.41.6",
    "webpack-cli": "3.3.11",
    "webpack-merge": "4.2.2"
  },
  "devDependencies": {
    "autoprefixer": "9.7.4",
    "browser-sync": "2.26.7",
    "clean-webpack-plugin": "3.0.0",
    "css-loader": "3.4.2",
    "html-minifier": "4.0.0",
    "husky": "4.2.3",
    "lint-staged": "10.0.8",
    "mini-css-extract-plugin": "0.9.0",
    "node-sass": "4.13.1",
    "onchange": "6.1.0",
    "postcss-loader": "3.0.0",
    "prettier": "1.19.1",
    "sass-loader": "8.0.2",
    "style-loader": "1.1.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,json,html,md,ts,css,scss,yaml,yml}": "prettier --write"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/napjoseph/napjoseph.github.io.git"
  },
  "homepage": "https://github.com/napjoseph/napjoseph.github.io#readme",
  "bugs": {
    "url": "https://github.com/napjoseph/napjoseph.github.io/issues"
  },
  "license": "MIT",
  "private": true
}
