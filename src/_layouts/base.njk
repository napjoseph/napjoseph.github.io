<!doctype html>
<html class="no-js" lang="en">
  <head>
    <meta charset="utf-8"/>
    <title>{{ title }} | {{ metadata.site.title }}</title>
    <meta name="description" content="{{ description or metadata.site.description }}"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>

    <link rel="manifest" href="/site.webmanifest"/>
    <link rel="apple-touch-icon" href="/icon.png"/>

    <!-- bundled styles -->
    <link rel="stylesheet" href="{{ "/main.css" | url }}" />

    <link rel="alternate"
          href="{{ metadata.feed.path | url }}"
          type="application/atom+xml"
          title="{{ metadata.site.title }}" />

    <meta name="theme-color" content="#fafafa"/>
  </head>
  <body>
    <header class="mb-10">
      <nav>
        <a href="{{ metadata.site.url }}" class="logo">
          {% include "logo.njk" %}
        </a>

        <ul>
        {%- for entry in collections.all | eleventyNavigation %}
          <li class="nav-item{% if entry.url == page.url %} nav-item-active{% endif %}">
            <a href="{{ entry.url | url }}">{{ entry.title }}</a>
          </li>
        {%- endfor %}
        </ul>
      </nav>
    </header>

    <main class="content">
      {{ content | safe }}
    </main>

    <footer class="mt-10">
      <div class="text-xs text-gray-600">
        <span>Copyright 2020 {{ metadata.author.name }}.</span>
        <span>View source at <a href="https://github.com/napjoseph/napjoseph.github.io">GitHub</a>.</span>
      </div>
    </footer>

    <!-- bundled scripts -->
    <script src="{{ "/main.js" | url }}"></script>
    <!-- google analytics, etc -->
    {% include "tracking.njk" %}
  </body>
</html>
