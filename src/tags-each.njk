---
layout: home
pagination:
  data: collections
  size: 1
  alias: tag
  filter:
    - all
    - nav
    - post
    - posts
    - tagsList
  addAllPagesToCollections: true
renderData:
  title: Tagged "{{ tag }}"
permalink: /tags/{{ tag }}/
---

<div>
  {% set postsList = collections[ tag ] %}

  {% include "posts-list.njk" %}
</div>

<p class="mt-5">See <a href="{{ '/tags/' | url }}">all tags</a>.</p>
